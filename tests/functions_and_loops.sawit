function add(a, b) {
  return a + b
}

function outer(x) {
  function inner(y) {
    return x + y
  }

  return inner(5)
}

let sum = add(2, 3)
print sum
print outer(10)

let i = 0
while i < 5 {
  i = i + 1

  if i == 2 {
    continue
  }

  if i == 4 {
    break
  }

  print i
}

for let j = 0; j < 3; j = j + 1 {
  print j
